# LLM
LLM_ENDPOINT=https://api.modelgate.ru
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=60s

# Per-agent LLM (опционально, наследуется от LLM_*)
LLM_ENDPOINT_COORDINATOR=
LLM_ENDPOINT_ANALYST=
LLM_ENDPOINT_CRITIC=
LLM_API_KEY_COORDINATOR=
LLM_API_KEY_ANALYST=
LLM_API_KEY_CRITIC=
LLM_MODEL_COORDINATOR=
LLM_MODEL_ANALYST=
LLM_MODEL_CRITIC=
LLM_TIMEOUT_COORDINATOR=
LLM_TIMEOUT_ANALYST=
LLM_TIMEOUT_CRITIC=

# Поиск
OPENSERP_URL=http://localhost:8080
SEARCH_ENGINE=duck
MAX_CONCURRENT_SEARCH=3
MAX_PAGES_PER_QUERY=3

# Эмбеддинги (chromem)
EMBEDDING_ENDPOINT=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# Кеш поиска
MIN_RELEVANT_FACTS=10
RECALL_TOP_K=15
RECALL_DISTANCE_THRESHOLD=0.5
RECALL_LLM_CHECK=true

# Исследование
MAX_ITERATIONS=3
MAX_CONCURRENT_SUBTOPICS=3
MAX_SUBTOPIC_RETRIES=2

# Хранилище
MEMORY_PATH=./data/malder_memory
SOURCE_STORE_PATH=

# Сервер
SERVER_PORT=8080

# Логирование
MALDER_LOG_LEVEL=info
MALDER_DEBUG_FILE=malder_debug.log
